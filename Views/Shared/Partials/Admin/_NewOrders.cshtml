@model List<Order>

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header pb-0">
                <h5 class="card-title">Son Siparişler</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th>Order Id</th>
                                <th>Username</th>
                                <th>Total</th>
                                <th>Date</th>
                                <th>State</th>
                                <th style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || !Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center">Henüz sipariş yok.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td>@order.Id</td>
                                        <td>@order.Username</td>
                                        <td>@order.ToplamFiyat ₺</td>
                                        <td>@order.SiparisTarihi.ToShortDateString()</td>
                                        <td>
                                            <span class="badge bg-primary">Onay Bekliyor</span>
                                        </td>
                                        <td>
                                            <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                                                class="btn btn-primary btn-sm">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>