# ----------------------------------------------
# .gitignore for ASP.NET Core (.NET 9) projects
# ----------------------------------------------

# Build results
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Bb]uild/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# Visual Studio / Rider / VS Code
.vs/
.vscode/
*.user
*.userosscache
*.suo
*.userprefs
*.rsuser
.idea/
*.swp

# OS junk
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------
# Secrets — NEVER commit these
# ----------------------------------------------
# Local secret overrides (real API keys, SMTP passwords, etc.)
appsettings.*.local.json
secrets.json
*.pfx

# ----------------------------------------------
# SQLite database files (data is generated/seeded at runtime)
# ----------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Misc
*.log
*.tmp
TestResults/
[Tt]est[Rr]esult*/